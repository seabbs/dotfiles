# Ghostty terminal configuration
# https://ghostty.org/docs/config

# Font
font-family = JetBrains Mono
font-size = 14

# Theme (matches nvim/tmux catppuccin)
theme = Catppuccin Macchiato

# Window
window-padding-x = 4
window-padding-y = 4
window-decoration = true
macos-titlebar-style = tabs

# Terminal
shell-integration = zsh
copy-on-select = clipboard
mouse-hide-while-typing = true

# Tabs act like machines: the first tab on launch is this machine (home tmux);
# any new tab (cmd+t) opens the archie hub (mosh). Switch with cmd+1 / cmd+2
# (or ctrl+tab). New local sessions live as tmux windows inside the home tab.
initial-command = /bin/zsh -l -c "tmux new-session -A -s home -c $HOME/code"
command = /bin/zsh -l -c "mosh archie"
