XAuthLocation /opt/X11/bin/xauth
TCPKeepAlive yes
ServerAliveInterval 30

# Personal Linux agents hub, reached over Tailscale (MagicDNS name).
# Multiplex connections so frequent calls (e.g. the status-bar agent monitor)
# reuse one fast connection instead of a fresh handshake each time.
Host archie
        HostName archie
        User seabbs
        Compression yes
        ControlMaster auto
        ControlPath ~/.ssh/cm-%r@%h:%p
        ControlPersist 10m

Host lshtm
        User lshsa2
        HostName pryor.lshtm.ac.uk
        Compression yes

Host macmini
        HostName macd0040.lshtm.ac.uk
        User lshsa2
        Compression yes
        ProxyJump lshtm

Host macmini-tunnel
        HostName macd0040.lshtm.ac.uk
        User lshsa2
        Compression yes
        LocalForward 9787 localhost:8787
        LocalForward 9888 localhost:8888
        LocalForward 9989 localhost:8989
        ProxyJump lshtm

Host pascal
       User seabbs
       HostName pascal.lshtm.ac.uk
       ForwardX11 yes
       ProxyJump lshtm

Host epiforecasts
       HostName 51.143.164.146
       User epiforecasts
       Compression yes
       IdentityFile ~/.ssh/epiforecasts-general-use.pem
